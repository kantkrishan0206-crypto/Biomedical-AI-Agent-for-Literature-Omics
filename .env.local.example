# Biomedical AI Agent for Literature + Omics
# Copy to .env.local for development or configure as platform secrets in Vercel/Render.

ENVIRONMENT=local
LOG_LEVEL=INFO
APP_OWNER_EMAIL=kantkrishan0206@gmail.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
RENDER_EXTERNAL_URL=https://biomedical-ai-agent.onrender.com
VERCEL_URL=https://biomedical-ai-agent.vercel.app

# Local development should point at PostgreSQL managed via pgAdmin4.
DATABASE_URL=postgresql+asyncpg://biomed:biomed@localhost:5432/biomedical_ai
DATABASE_SSL_MODE=prefer
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

JWT_SECRET=replace-with-64-random-characters
SESSION_SECRET=replace-with-64-random-characters
ENCRYPTION_KEY=replace-with-32-byte-base64-key
UPLOAD_ENCRYPTION_KEY=replace-with-32-byte-base64-key
TELEMETRY_API_KEY=replace-with-random-token
GITHUB_TOKEN=
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=

SINGLE_USER_DEV_MODE=true
FIRST_ADMIN_EMAIL=kantkrishan0206@gmail.com
CORS_ORIGINS=http://localhost:3000
MAX_UPLOAD_MB=512
